---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  ratio?: string;
  priority?: boolean;
  widths?: number[];
  sizes?: string;
}
const {
  image,
  alt,
  ratio = '4 / 3',
  priority = false,
  widths = [400, 700, 1000, 1400],
  sizes = '(max-width: 700px) 100vw, 700px',
} = Astro.props;
---

<div class="site-photo" style={`aspect-ratio: ${ratio};`}>
  <Image
    src={image}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={priority ? 'eager' : 'lazy'}
    decoding={priority ? 'sync' : 'async'}
  />
</div>

<style>
  .site-photo {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .site-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
