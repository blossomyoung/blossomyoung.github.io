---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="Page not found" noindex>
  <section class="section not-found">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>We couldn't find that page</h1>
      <p>The page you're looking for may have moved or no longer exists.</p>
      <a class="btn btn--primary" href="/">Back to home</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found { text-align: center; padding: 6rem 0; }
  .not-found p { max-width: 46ch; margin: 0 auto 1.5rem; color: var(--color-text-muted); }
</style>
