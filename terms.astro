---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';
---

<BaseLayout title="Terms of Use" description="Terms of Use" noindex>
  <section class="section section--tight legal">
    <div class="container">
      <h1>Terms of Use</h1>
      <p class="updated">Last updated: [TODO: date]</p>

      <h2>Using this site</h2>
      <p>
        This website provides information about {site.title}'s work as {site.role} and a way to
        get in touch or raise casework. Content is provided in good faith and kept up to date on a
        best-efforts basis, but we make no guarantee it is complete or error-free at every moment.
      </p>

      <h2>Casework enquiries</h2>
      <p>
        Submitting a casework enquiry through this site does not guarantee a particular outcome —
        it means {site.title} or her office will look into the matter and respond as promptly as
        possible. For urgent or safety issues, contact the relevant emergency service or
        {site.council} directly rather than relying solely on this site.
      </p>

      <h2>Intellectual property</h2>
      <p>
        Text and images on this site belong to {site.title} or are used with permission, unless
        otherwise stated. Please don't reproduce content from this site without permission.
      </p>

      <h2>Changes to these terms</h2>
      <p>These terms may be updated from time to time; the current version always applies.</p>

      <h2>Contact</h2>
      <p>Questions about these terms can be sent to <a href={`mailto:${site.email}`}>{site.email}</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .legal { max-width: 760px; margin: 0 auto; }
  .legal h2 { margin-top: 2rem; }
  .updated { color: var(--color-text-muted); font-size: 0.9rem; }
</style>
