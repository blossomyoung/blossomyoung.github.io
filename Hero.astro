---
import PlaceholderPhoto from './PlaceholderPhoto.astro';
interface Props {
  eyebrow?: string;
  headline: string;
  intro: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}
const { eyebrow, headline, intro, primaryCta, secondaryCta } = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{headline}</h1>
      <p class="hero__intro">{intro}</p>
      <div class="hero__ctas">
        {primaryCta && <a class="btn btn--primary" href={primaryCta.href}>{primaryCta.label}</a>}
        {secondaryCta && <a class="btn btn--secondary" href={secondaryCta.href}>{secondaryCta.label}</a>}
      </div>
    </div>
    <div class="hero__photo">
      <slot name="photo">
        <PlaceholderPhoto label="Photo of Blossom Young" tone="red" ratio="1 / 1" />
      </slot>
    </div>
  </div>
</section>

<style>
  .hero { padding: 3rem 0 2rem; }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero__intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 42ch;
  }
  .hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .hero__photo { max-width: 360px; margin: 0 auto; }
  @media (max-width: 780px) {
    .hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero__photo { order: -1; max-width: 240px; }
  }
</style>
