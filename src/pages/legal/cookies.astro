---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';
---

<BaseLayout title="Cookie Policy" description="Cookie Policy" noindex>
  <section class="section section--tight legal">
    <div class="container">
      <h1>Cookie Policy</h1>
      <p class="updated">Last updated: [TODO: date]</p>

      <h2>What are cookies</h2>
      <p>
        Cookies are small text files stored on your device when you visit a website. This site is
        built to avoid non-essential cookies wherever possible.
      </p>

      <h2>Cookies used on this site</h2>
      <p>
        This site does not use analytics or advertising cookies. Form submissions are handled by
        Formspree, which may set a functional cookie needed to process your submission securely.
        No tracking or profiling cookies are set by this site itself.
      </p>

      <h2>Managing cookies</h2>
      <p>
        You can control or delete cookies through your browser settings. Blocking cookies entirely
        may affect the functioning of the contact and casework forms on this site.
      </p>

      <h2>Contact</h2>
      <p>Questions about this policy can be sent to <a href={`mailto:${site.email}`}>{site.email}</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .legal { max-width: 760px; margin: 0 auto; }
  .legal h2 { margin-top: 2rem; }
  .updated { color: var(--color-text-muted); font-size: 0.9rem; }
</style>
