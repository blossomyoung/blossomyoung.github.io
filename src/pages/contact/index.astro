---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import SocialBar from '../../components/SocialBar.astro';
import { site } from '../../lib/site';
---

<BaseLayout title="Contact" description={`Get in touch with ${site.title}, your local councillor for ${site.ward}.`}>
  <section class="section section--tight">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>Get in touch</h1>
        <p class="intro">Have a question or need help with something? Send a message and I'll get back to you.</p>
        <ContactForm variant="general" />
      </div>

      <aside class="card contact-details">
        <h2>Direct contact</h2>
        <p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
        {site.phone && <p><strong>Phone:</strong> <a href={`tel:${site.phone}`}>{site.phone}</a></p>}
        {site.officeAddress && <p><strong>Office:</strong> {site.officeAddress}</p>}

        <h2>Ward surgery</h2>
        <p><strong>When:</strong> {site.surgery.schedule}</p>
        <p><strong>Where:</strong> {site.surgery.location}</p>

        <h2>Follow along</h2>
        <SocialBar variant="dark" />
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .intro { color: var(--color-text-muted); max-width: 55ch; }
  .contact-details h2 { font-size: 1.05rem; margin-top: 1.5rem; }
  .contact-details h2:first-child { margin-top: 0; }
  @media (max-width: 780px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
