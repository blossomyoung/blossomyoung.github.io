---
interface Props {
  label: string;
  tone?: 'red' | 'gold' | 'ink';
  ratio?: string;
}
const { label, tone = 'red', ratio = '1 / 1' } = Astro.props;

const tones: Record<string, [string, string]> = {
  red: ['#e4003b', '#7a2530'],
  gold: ['#e8a33d', '#5c1a22'],
  ink: ['#161513', '#5c1a22'],
};
const [from, to] = tones[tone];
---

<div class="placeholder" style={`aspect-ratio: ${ratio}; background: linear-gradient(135deg, ${from}, ${to});`} role="img" aria-label={`Placeholder image: ${label}`}>
  <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#fff" stroke-width="1.5" aria-hidden="true">
    <rect x="3" y="3" width="18" height="18" rx="2" />
    <circle cx="8.5" cy="8.5" r="1.5" />
    <path d="M21 15l-5-5L5 21" />
  </svg>
  <span class="placeholder__label">{label}</span>
</div>

<style>
  .placeholder {
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #fff;
    width: 100%;
    overflow: hidden;
  }
  .placeholder__label {
    font-size: 0.8rem;
    font-weight: 600;
    text-align: center;
    padding: 0 1rem;
    opacity: 0.9;
  }
</style>
