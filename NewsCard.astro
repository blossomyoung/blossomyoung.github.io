---
import SitePhoto from './SitePhoto.astro';
import PlaceholderPhoto from './PlaceholderPhoto.astro';
import { getNewsImage } from '../lib/newsImages';

interface Props {
  slug: string;
  title: string;
  date: Date;
  category: string;
  excerpt: string;
  imageAlt: string;
}
const { slug, title, date, category, excerpt, imageAlt } = Astro.props;
const realImage = getNewsImage(slug);
const formattedDate = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<a class="news-card" href={`/news/${slug}/`}>
  <div class="news-card__media">
    {realImage
      ? <SitePhoto image={realImage} alt={imageAlt} ratio="16 / 10" />
      : <PlaceholderPhoto label={title} tone="gold" ratio="16 / 10" />}
  </div>
  <div class="news-card__body">
    <p class="news-card__category">{category} · {formattedDate}</p>
    <h3>{title}</h3>
    <p class="news-card__excerpt">{excerpt}</p>
  </div>
</a>

<style>
  .news-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.15s ease;
  }
  .news-card:hover { transform: translateY(-3px); }
  .news-card__body { padding: 1.25rem 1.5rem 1.5rem; }
  .news-card__category {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .news-card h3 { margin-bottom: 0.4rem; font-size: 1.1rem; }
  .news-card__excerpt {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
